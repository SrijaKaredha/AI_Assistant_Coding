#TASK-3
import pandas as pd
import numpy as np
from sklearn.preprocessing import LabelEncoder, StandardScaler
from sklearn.model_selection import train_test_split

# Create a synthetic student health dataset
data = {
    'student_id': range(1, 21),
    'age': [15, 16, 15, 17, 16, 15, 17, 16, 15, 17, 16, 15, 17, 16, 15, 17, 16, 15, 17, 16],
    'height_cm': [160, 175, 162, 180, 168, 165, 170, 172, 163, 178, 169, 161, 176, 171, 164, 179, 173, 166, 181, 174],
    'weight_kg': [55, 70, 58, 75, 62, 60, 68, 70, 56, 73, 65, 57, 72, 69, 59, 76, 71, 61, 78, 74],
    'medical_condition': ['None', 'Asthma', 'Allergy', 'None', 'None', 'Asthma', 'None', 'Allergy', 'None', 'None', 'Asthma', 'None', 'None', 'Allergy', 'None', 'None', 'Asthma', 'None', 'None', 'Allergy'],
    'fitness_status': ['Good', 'Excellent', 'Average', 'Excellent', 'Good', 'Average', 'Excellent', 'Good', 'Average', 'Excellent', 'Good', 'Average', 'Excellent', 'Good', 'Average', 'Excellent', 'Good', 'Average', 'Excellent', 'Good']
}
df_health = pd.DataFrame(data)

# Introduce some missing values intentionally
df_health.loc[0, 'height_cm'] = np.nan
df_health.loc[4, 'weight_kg'] = np.nan
df_health.loc[8, 'medical_condition'] = np.nan
df_health.loc[12, 'fitness_status'] = np.nan

# Calculate BMI (Body Mass Index) - weight (kg) / (height (m))^2
df_health['bmi'] = df_health['weight_kg'] / ((df_health['height_cm'] / 100)**2)

# Introduce a missing BMI intentionally
df_health.loc[1, 'bmi'] = np.nan

print("Original Student Health DataFrame:")
display(df_health)
df_health.info()

